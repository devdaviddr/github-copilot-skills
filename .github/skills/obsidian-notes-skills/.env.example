# Copy this file to .env and fill in your secret token. DO NOT commit your .env to git.
# Recommended: keep the token outside the repo (see ENV_SETUP.md) and add .env to .gitignore.

# Obsidian HTTP API bearer token (keep secret)
OBSIDIAN_API_TOKEN=<your_token_here>

# API host (default to local Obsidian plugin HTTPS endpoint)
OBSIDIAN_API_HOST=https://127.0.0.1:27124
